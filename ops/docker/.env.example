# Copy this file to ops/docker/.env and fill in your values.
# Never commit .env with real secrets.

# ── Symfony ───────────────────────────────────────────────────────────────
APP_SECRET=change-me-to-a-random-32-char-string

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_DB=home_users
POSTGRES_USER=app
POSTGRES_PASSWORD=secret

# ── Exposed ports (dev only) ──────────────────────────────────────────────
NGINX_PORT=8080
POSTGRES_PORT=5432
